@article{doi:10.1089/end.2023.0697,
author = {Bakker, Aron F.H.A. and de Nijs, Joris V. and Jaspers, Tim J.M. and de With, Peter H.N. and Beulens, Alexander J.W. and van der Poel, Henk G. and van der Sommen, Fons and Brinkman, Willem M.},
title = {Estimating Surgical Urethral Length on Intraoperative Robot-Assisted Prostatectomy Images Using Artificial Intelligence Anatomy Recognition},
journal = {Journal of Endourology},
volume = {38},
number = {7},
pages = {690-696},
year = {2024},
