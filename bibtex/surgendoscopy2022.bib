@article{denBoer2022,
  author    = {den Boer, R. B. and de Jongh, C. and Huijbers, W. T. E. and Jaspers, T. J. M. and Pluim, J. P. W. and van Hillegersberg, R. and Van Eijnatten, M. and Ruurda, J. P.},
  title     = {Computer-aided anatomy recognition in intrathoracic and -abdominal surgery: a systematic review},
  journal   = {Surgical Endoscopy},
  year      = {2022},
  volume    = {36},
  number    = {12},
  pages     = {8737--8752},
  doi       = {10.1007/s00464-022-09421-5},
  url       = {https://doi.org/10.1007/s00464-022-09421-5},
  issn      = {1432-2218},
  abstract  = {Minimally invasive surgery is complex and associated with substantial learning curves. Computer-aided anatomy recognition, such as artificial intelligence-based algorithms, may improve anatomical orientation, prevent tissue injury, and improve learning curves. This study provides a comprehensive overview of current literature on the accuracy of anatomy recognition algorithms in intrathoracic and intra-abdominal surgery.}
